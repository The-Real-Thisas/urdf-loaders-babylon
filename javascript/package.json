{
  "name": "urdf-loader-babylonjs",
  "version": "0.1.0",
  "description": "URDF Loader for Babylon.js and webcomponent viewer",
  "main": "src/URDFLoader.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"rollup -w -c\" \"vite --config ./vite.config.js\"",
    "build": "rollup -c",
    "build-examples": "vite build --config ./vite.config.js",
    "test": "vitest run",
    "lint": "eslint \"./src/*.js\" \"./test/*.js\" && tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "src/*",
    "umd/*"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "javascript",
    "babylonjs",
    "babylon.js",
    "graphics",
    "ros",
    "robotics",
    "urdf",
    "urdf-models",
    "webcomponents"
  ],
  "peerDependencies": {
    "@babylonjs/core": ">=6.0.0",
    "@babylonjs/loaders": ">=6.0.0"
  },
  "devDependencies": {
    "@babylonjs/core": "^7.0.0",
    "@babylonjs/loaders": "^7.0.0",
    "@eslint/js": "^9.19.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@vitest/eslint-plugin": "^1.1.25",
    "@webcomponents/webcomponentsjs": "^2.4.4",
    "concurrently": "^6.2.1",
    "eslint": "^9.19.0",
    "globals": "^15.14.0",
    "jsdom": "^17.0.0",
    "node-fetch": "^3.0.0",
    "vite": "^6.2.2",
    "rollup": "^4.32.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "dependencies": {}
}
